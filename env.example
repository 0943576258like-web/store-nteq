# ═══════════════════════════════════════════
# ตั้งค่าอีเมล Outlook / Microsoft 365 สำหรับส่ง OTP
# ═══════════════════════════════════════════
# 1. คัดลอกไฟล์นี้เป็นชื่อ .env
# 2. ใส่อีเมลและรหัสผ่านจริงของบัญชีที่จะใช้ส่ง OTP
# 3. ห้าม commit ไฟล์ .env เข้า git โดยเด็ดขาด (ใส่ .env ใน .gitignore)

SMTP_USER=you@yourcompany.com
SMTP_PASS=your_password_here

# พอร์ตที่ server จะรัน (ไม่บังคับ ค่าเริ่มต้น 3000)
PORT=3000
